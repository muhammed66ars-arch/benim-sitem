<style>

*{
margin:0;
padding:0;
box-sizing:border-box;
}

body{
font-family:'Poppins',sans-serif;
background:#0a0a0a;
color:white;
overflow-x:hidden;
}

/* NAVBAR */

nav{
display:flex;
justify-content:space-between;
align-items:center;
padding:25px 10%;
background:#111;
border-bottom:1px solid #222;
position:sticky;
top:0;
}

nav h1{
color:orange;
font-size:30px;
}

nav ul{
display:flex;
list-style:none;
gap:25px;
}

nav a{
text-decoration:none;
color:white;
transition:0.3s;
}

nav a:hover{
color:orange;
}

/* HERO */

.hero{
height:100vh;
display:flex;
justify-content:center;
align-items:center;
flex-direction:column;
text-align:center;
padding:20px;
background:radial-gradient(circle,#151515,#0a0a0a);
}

.hero h2{
font-size:70px;
margin-bottom:15px;
animation:slide 1.5s ease;
}

.hero span{
color:orange;
text-shadow:0 0 20px orange;
}

.hero p{
color:#aaa;
font-size:22px;
margin-bottom:30px;
animation:fade 2s ease;
}

.btn{
padding:15px 35px;
background:orange;
border:none;
border-radius:12px;
font-size:17px;
font-weight:bold;
cursor:pointer;
transition:0.3s;
}

.btn:hover{
transform:scale(1.1);
background:white;
}

/* BÖLÜMLER */

section{
padding:100px 10%;
}

.title{
font-size:40px;
margin-bottom:40px;
color:orange;
}

.card{
background:#151515;
padding:25px;
border-radius:15px;
margin-bottom:20px;
border:1px solid #222;
transition:0.3s;
}

.card:hover{
transform:translateY(-10px);
box-shadow:0 0 25px rgba(255,165,0,0.3);
}

/* PROJELER */

.projects{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
gap:20px;
}

/* FOOTER */

footer{
text-align:center;
padding:30px;
background:#111;
color:#777;
}

/* ANİMASYON */

@keyframes slide{

from{
transform:translateY(-50px);
opacity:0;
}

to{
transform:translateY(0);
opacity:1;
}

}

@keyframes fade{

from{
opacity:0;
}

to{
opacity:1;
}

}

/* MOBİL */

@media(max-width:768px){

.hero h2{
font-size:45px;
}

nav{
flex-direction:column;
gap:15px;
}

}

</style>

